# Copy this file to .env.local (for local dev) and fill in real values.
# Never commit the real .env.local — it's already gitignored.

# Neon Postgres connection string (free tier). Get this from your Neon project
# dashboard: neon.tech -> your project -> Connect -> "Prisma" tab, it gives you
# a ready-to-paste connection string. Must include ?sslmode=require.
DATABASE_URL="postgresql://user:password@ep-example-12345.region.aws.neon.tech/neondb?sslmode=require"

# Secret used by NextAuth (Auth.js v5) to sign session tokens. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"
