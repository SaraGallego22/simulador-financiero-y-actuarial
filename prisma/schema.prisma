// Data model for the Simulador Financiero y Actuarial platform.
// See CLAUDE.md §7 for the rationale behind each modeling choice
// (cohort isolation, Bytes columns instead of a blob service, published flags).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  team         Team?    @relation(fields: [teamId], references: [id])
  teamId       String?  @unique
  createdAt    DateTime @default(now())
}

model Cohort {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  teams          Team[]
  universeRuns   UniverseRun[]
  simulationRuns SimulationRun[]
  rubricConfig   RubricConfig?
}

model Team {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id])
  name      String
  color     String
  createdAt DateTime @default(now())

  user                     User?
  members                  TeamMember[]
  tariffSubmissions        TariffSubmission[]
  portfolioAllocations     PortfolioAllocation[]
  deliverables             Deliverable[]
  analyticsRecommendations AnalyticsRecommendation[]
  simResults               TeamSimResult[]

  @@unique([cohortId, name])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name   String

  evaluations MemberDayEvaluation[]
}

// Bulk-generated reference datasets (Colombia universe, Chile reference set).
// `data` holds the serialized typed array directly as a Postgres bytea column —
// no separate blob service (see CLAUDE.md §3/§4.1).
model UniverseRun {
  id         String    @id @default(cuid())
  cohortId   String
  cohort     Cohort    @relation(fields: [cohortId], references: [id])
  kind       String // "colombia" | "chile"
  seed       Int
  rowCount   Int
  status     JobStatus @default(PENDING)
  data       Bytes?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
}

// One market-clearing simulation run for a given challenge day/year.
// `resultData` is the full per-policy team assignment, kept only for audit/export;
// the numbers the UI actually queries live in TeamSimResult.
model SimulationRun {
  id         String    @id @default(cuid())
  cohortId   String
  cohort     Cohort    @relation(fields: [cohortId], references: [id])
  day        Int
  status     JobStatus @default(PENDING)
  params     Json
  resultData Bytes?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  teamResults TeamSimResult[]
}

model TeamSimResult {
  id              String        @id @default(cuid())
  simulationRunId String
  simulationRun   SimulationRun @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team          @relation(fields: [teamId], references: [id])

  insuredCount  Int
  totalPremium  Float
  claimsCount   Int
  claimsAmount  Float
  rejectedCount Int
  // Catch-all for the many finBench/almSim/scoreFinanciero output fields
  // (P&L lines, balance sheet, solvency ratios, NAV sensitivities) — kept as
  // Json until the engine port stabilizes their exact shape (see CLAUDE.md §7).
  extra         Json

  published Boolean @default(false)

  @@unique([simulationRunId, teamId])
}

model TariffSubmission {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  day         Int
  // Null when outsourced=true — the emergency tariff is a deterministic
  // function of the universe seed alone (see generateOutsourcedTariff() in
  // domain/pricing/outsourced.ts), so it's regenerated on demand instead of
  // storing another ~4MB bytea per team, exactly like the universe itself
  // (see CLAUDE.md §4.1).
  data        Bytes?
  meanPremium Float?
  // True when this team hit "Tercerizar tarifas" instead of uploading its
  // own CSV for this day — narratively, an emergency-outsourced tariff from
  // an inexperienced consultancy (see the outsource route's doc comment).
  outsourced  Boolean  @default(false)
  submittedAt DateTime @default(now())

  @@unique([teamId, day])
}

model PortfolioAllocation {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  day         Int
  allocation  Json
  submittedAt DateTime @default(now())

  @@unique([teamId, day])
}

model Deliverable {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  day         Int
  conceptId   String
  value       Float
  submittedAt DateTime @default(now())

  @@unique([teamId, day, conceptId])
}

// A team's ranked pick within one of its two Día 4 sector lists — one row
// per (team, day, list, rank). A "sector" is a cross of two dimensions
// (dimA=valA x dimB=valB, e.g. zona=urbana x uso=comercial), not a single
// segment — see domain/grading/sectors.ts.
model AnalyticsRecommendation {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])
  day    Int
  list   String // 'crecer' | 'disminuir'
  rank   Int // 1-based position within that list
  dimA   String
  valA   String
  dimB   String
  valB   String

  @@unique([teamId, day, list, rank])
}

model RubricConfig {
  id       String @id @default(cuid())
  cohortId String @unique
  cohort   Cohort @relation(fields: [cohortId], references: [id])

  subjectiveWeight Float  @default(0.30)
  actuarialWeight  Float  @default(0.50)
  objectiveMode    String @default("relative")
  tolerancePerfect Float  @default(0.05)
  toleranceZero    Float  @default(0.40)
}

enum EvaluationProfile {
  ACTUARIAL
  FINANCIERO
  GENERALISTA
}

// Per-participant subjective evaluation for one day. Only Días 2-4 — Día 1 has
// no subjective grade (not enough contact time yet to judge each member).
// `aprobado` is independent of `notaGeneral` (see composite.ts's notaDia:
// only notaGeneral feeds the numeric grade; aprobado/perfil/comentario are
// reporting fields the evaluator fills in alongside it).
model MemberDayEvaluation {
  id              String             @id @default(cuid())
  teamMemberId    String
  teamMember      TeamMember         @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  day             Int
  notaGeneral     Float? // 1.0-5.0, one decimal
  aprobado        Boolean?
  perfil          EvaluationProfile?
  comentario      String?
  comentarioAutor String? // name of the evaluator who wrote the comment

  published Boolean @default(false)

  @@unique([teamMemberId, day])
}
